// advoc.me — schema Prisma
// Espelha os tipos em frontend/src/lib/types.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  premium
}

enum SocialKind {
  instagram
  linkedin
  website
  facebook
  youtube
  tiktok
}

// Estado da conferência de OAB (workflow) — a marca "OAB conferida" só quando `verified`.
enum OabStatus {
  none
  pending
  verified
  rejected
}

// Estado de moderação do perfil (resultado de denúncias avaliadas pelo admin).
//   active   → sem restrição
//   warned   → dono recebeu aviso, perfil segue no ar
//   partial  → algumas seções foram censuradas (ver Profile.hiddenSections)
//   restricted → perfil inteiro retirado do ar (não aparece no público/diretório)
enum ModerationStatus {
  active
  warned
  partial
  restricted
}

// Situação de uma denúncia na fila do admin.
enum ReportStatus {
  open
  resolved
  dismissed
}

// Papel de um advogado dentro do escritório (sociedade de advogados).
//   owner  → dono/faturamento (1 por escritório)
//   admin  → edita a página institucional e convida membros
//   member → advogado listado; edita apenas o próprio perfil
enum FirmRole {
  owner
  admin
  member
}

// Estado do vínculo do advogado com o escritório.
//   invited → convite enviado; NÃO consome assento nem aparece no grid público
//   active  → consome assento e aparece no grid
enum FirmMemberStatus {
  invited
  active
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hash (argon2)
  createdAt DateTime @default(now())
  profile   Profile?
  // Escritórios dos quais este usuário é dono/faturamento (normalmente 0 ou 1).
  firmsOwned Firm[]
}

// Escritório (sociedade de advogados) — página institucional. Cada advogado listado
// mantém seu Profile individual; o vínculo é feito por FirmMembership. Registro da
// SOCIEDADE na OAB é conferido à parte da OAB individual de cada advogado.
model Firm {
  id          String    @id @default(cuid())
  slug        String    @unique // advoc.me/escritorio/<slug>
  name        String
  oabRegistry String // registro da SOCIEDADE (≠ OAB individual dos advogados)
  oabStatus   OabStatus @default(none) // reutiliza o workflow de conferência
  oabVerified Boolean   @default(false)
  monogram    String    @default("")
  logoUrl     String?
  tagline     String    @default("")
  about       String    @default("")
  city        String    @default("")
  state       String    @default("")
  // Contato INSTITUCIONAL (separado das redes pessoais de cada advogado)
  phone     String?
  email     String?
  whatsapp  String?
  instagram String?
  linkedin  String?
  // ---- White-label canônico do escritório (membros herdam a marca) ----
  brandAccent  String? // cor de destaque (hex)
  customDomain String? // domínio próprio (informativo no protótipo)
  // ---- Plano / assentos (billing real entra depois; hoje é campo, como Profile.plan) ----
  plan           Plan @default(premium) // escritório opera no tier alto
  seatsPurchased Int  @default(5) // base do plano Escritório inclui 5 assentos

  ownerUserId String
  ownerUser   User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     FirmMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, state])
}

// Vínculo advogado ↔ escritório. Um advogado pertence a no máximo um escritório
// (profileId @unique). O `order` é apenas para ordenação interna — NUNCA para ranking
// público (Prov. 205/2021 veda destaque/hierarquia): o grid é sempre alfabético.
model FirmMembership {
  id        String           @id @default(cuid())
  role      FirmRole         @default(member)
  status    FirmMemberStatus @default(invited)
  order     Int              @default(0)
  createdAt DateTime         @default(now())

  firmId    String
  firm      Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
}

model Profile {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  oabNumber   String
  oabVerified Boolean   @default(false) // espelha (oabStatus == verified) — usado na UI
  oabStatus   OabStatus @default(none)
  headline    String   @default("")
  bio         String   @default("")
  avatarUrl   String?
  city        String   @default("")
  state       String   @default("")
  regionNote  String?
  inPerson    Boolean  @default(true)
  online      Boolean  @default(true)
  whatsapp    String?
  email       String?
  scheduling  String?
  plan        Plan     @default(free)
  theme       String   @default("papel") // ThemeId — ver frontend/src/lib/themes.ts
  views       Int      @default(0)
  published   Boolean  @default(false)
  // Versão da política de publicidade (Provimento) aplicada à última verificação.
  policyVersion String @default("Prov. 205/2021")
  // Revisão do conjunto de regras (RULESET_REV) conferida na última verificação.
  // Monitor de mudanças normativas: se a revisão vigente for maior, o perfil é
  // reavaliado e o advogado é avisado. Ver src/oab/compliance.ts (policyOutdated).
  policyRevChecked Int @default(0)
  // ---- Identidade própria (white-label) — plano Premium/Escritório ----
  // Não afeta conformidade: o conteúdo segue sujeito ao Prov. 205/2021.
  brandName          String?
  brandAccent        String? // cor de destaque personalizada (hex)
  brandHideWatermark Boolean @default(false)
  customDomain       String? // domínio próprio (informativo; DNS fora do escopo do protótipo)
  // ---- Moderação (denúncias) ----
  moderationStatus ModerationStatus @default(active)
  // Aviso do admin visível ao dono do perfil (motivo do aviso/restrição).
  moderationNote   String           @default("")
  // Seções censuradas quando moderationStatus == partial. JSON de chaves,
  // ex.: ["bio","socials","area:<id>"]. Aplicado no getBySlug (público).
  hiddenSections   String           @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  areas      PracticeArea[]
  highlights Highlight[]
  socials    SocialLink[]
  events     LinkEvent[]
  auditLogs  AuditLog[]
  reports    Report[]
  // Vínculo com um escritório (opcional). Presente quando o advogado integra uma sociedade.
  firmMembership FirmMembership?

  @@index([city, state])
}

// Denúncia feita por qualquer visitante sobre um perfil (conteúdo que viola as
// normas da OAB / REGRAS.md). Anônima por padrão; e-mail opcional para retorno.
model Report {
  id            String       @id @default(cuid())
  profileId     String
  profile       Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // Motivo pré-pronto (ver src/moderation/moderation.constants.ts) ou "other".
  reason        String
  // Descrição livre do denunciante (o que/onde viola).
  details       String       @default("")
  // Contato opcional do denunciante para retorno (pode ficar vazio).
  reporterEmail String?
  status        ReportStatus @default(open)
  // Decisão aplicada ao resolver: "warn" | "partial" | "restrict" | "dismiss".
  resolution    String?
  createdAt     DateTime     @default(now())
  handledAt     DateTime?

  @@index([profileId, status])
  @@index([status, createdAt])
}

model PracticeArea {
  id          String  @id @default(cuid())
  label       String
  description String  @default("")
  order       Int     @default(0)
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Highlight {
  id        String  @id @default(cuid())
  title     String
  detail    String  @default("")
  order     Int     @default(0)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model SocialLink {
  id        String     @id @default(cuid())
  kind      SocialKind
  url       String
  profileId String
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, kind])
}

// Analytics de cliques/visitas
model LinkEvent {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind      String // "view" | "whatsapp" | "scheduling" | "social:instagram" ...
  createdAt DateTime @default(now())

  @@index([profileId, kind])
}

// Trilha de auditoria imutável das alterações de perfil e do resultado de conformidade.
// Dados pessoais minimizados: guardamos apenas o snapshot da bio (conteúdo público),
// status de compliance e a versão da política. Limpar registros antigos conforme LGPD.
model AuditLog {
  id               String   @id @default(cuid())
  profileId        String
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action           String // "update" | "publish" | "unpublish" | "blocked"
  complianceStatus String // "ok" | "warn" | "block"
  policyVersion    String
  bioSnapshot      String   @default("") // conteúdo público da bio no momento
  createdAt        DateTime @default(now())

  @@index([profileId, createdAt])
}

// Camada de política versionada — permite atualizar as regras do Provimento sem
// depender de deploy e manter histórico (ex.: revisão futura do Prov. 205/2021).
model PolicyVersion {
  id          String   @id @default(cuid())
  version     String   @unique // ex.: "Prov. 205/2021"
  rulesetRev  Int      @default(1) // revisão interna do conjunto de regras
  description String   @default("")
  effectiveAt DateTime @default(now())
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}
