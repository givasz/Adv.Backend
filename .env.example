# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advocme?schema=public"

# IA — escolha o provider
AI_PROVIDER="ollama"          # "ollama" (local, grátis) ou "anthropic"
AI_MODEL="llama3.2:3b"        # ollama: llama3.2:3b · anthropic: claude-sonnet-5
OLLAMA_URL="http://localhost:11434"

# Anthropic (usado quando AI_PROVIDER != ollama)
ANTHROPIC_API_KEY="sk-ant-..."

# CORS / servidor
FRONTEND_ORIGIN="http://localhost:5173"
PORT=3333

# Admin (conferência de OAB) — protótipo. Em produção: auth real + papel de admin.
ADMIN_TOKEN="troque-este-token"
