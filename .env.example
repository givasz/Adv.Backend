# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advocme?schema=public"

# IA — escolha o provider: "ollama" (local, grátis) · "gemini" (grátis) · "anthropic" (pago)
AI_PROVIDER="ollama"
AI_MODEL="llama3.2:3b"        # ollama: llama3.2:3b · gemini: gemini-2.5-flash · anthropic: claude-sonnet-5
OLLAMA_URL="http://localhost:11434"

# Gemini (tier grátis) — chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# Anthropic (quando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# CORS / servidor
FRONTEND_ORIGIN="http://localhost:5173"
PORT=3333

# Admin — login do painel de moderação (denúncias) e da fila de OAB.
# ADMIN_TOKEN segue aceito como token estático legado (header x-admin-token).
ADMIN_TOKEN="troque-este-token"
# Login do painel escondido (rota /painel-...). Defina credenciais fortes em produção.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="troque-esta-senha"
# Segredo para assinar o token de sessão do admin (HMAC). Valor longo e aleatório.
ADMIN_SESSION_SECRET="troque-por-um-segredo-longo-aleatorio"
