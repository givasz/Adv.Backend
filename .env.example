# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advocme?schema=public"

# IA — escolha o provider: "ollama" (local, grátis) · "gemini" (grátis) · "anthropic" (pago)
AI_PROVIDER="ollama"
AI_MODEL="llama3.2:3b"        # ollama: llama3.2:3b · gemini: gemini-2.5-flash · anthropic: claude-sonnet-5
OLLAMA_URL="http://localhost:11434"

# Gemini (tier grátis) — chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# Anthropic (quando AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# CORS / servidor
FRONTEND_ORIGIN="http://localhost:5173"
PORT=3333

# Admin (conferência de OAB) — protótipo. Em produção: auth real + papel de admin.
ADMIN_TOKEN="troque-este-token"
